    "test": "vitest",
    "test:unit": "vitest tests/unit",
    "test:integration": "vitest tests/integration",
    "test:watch": "vitest --watch",
    "generate": "prisma generate",
    "prebuild": "prisma generate",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "kb:ingest": "ts-node --compiler-options '{\"module\":\"CommonJS\"}' scripts/ingest-kb.ts",
    "seed": "prisma db seed",
    "seed:notifs": "ts-node prisma/seedNotifications.ts"
  },
  "prisma": {
